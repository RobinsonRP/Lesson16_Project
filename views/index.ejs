<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <title>Student List App</title>

  <style>
    .table-container {
      width: 900px;
      margin: 40px auto;
      text-align: center;
    }

    table img {
      width: 60px;
      height: 60px;
      object-fit: cover;
      border: 1px solid #ccc;
    }

    table {
      margin-top: 20px;
    }

    /* Plain link-style buttons */
    .action-link {
      background-color: #e9e9e9;
      border: 1px solid #000;
      color: #000;
      padding: 4px 10px;
      border-radius: 0;
      text-decoration: none;
      font-family: inherit;
      font-size: 14px;
      display: inline-block;
    }

    .action-link:hover {
      background-color: #d9d9d9;
      color: #000;
    }
  </style>
</head>

<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Student List App</a>

      <button class="navbar-toggler" type="button"
        data-bs-toggle="collapse"
        data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/addStudent">Add new student</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="table-container">

    <h2>Student Database</h2>

    <table class="table table-hover text-center align-middle table-bordered">

      <thead class="table-dark">
        <tr>
          <th>Student Name</th>
          <th>Student Image</th>
          <th>Dob</th>
          <th>Contact</th>
          <th>Edit</th>
          <th>Delete</th>
        </tr>
      </thead>

      <tbody>
        <% for(let i = 0; i < students.length; i++) { %>
          <tr>
            <td><%= students[i].name %></td>
            <td>
              <% if (students[i].image) { %>
                <img src="<%= students[i].image %>" alt="Student Image">
              <% } else { %>
                <span class="text-muted">No image</span>
              <% } %>
            </td>
            <td>
              <%= new Date(students[i].dob).toLocaleDateString('en-GB', {
                day: '2-digit',
                month: 'short',
                year: 'numeric'
              }) %>
            </td>
            <td><%= students[i].contact %></td>
            <td>
              <a href="/updateStudent/<%= students[i].studentId %>" class="action-link">Edit</a>
            </td>
            <td>
              <a href="/deleteStudent/<%= students[i].studentId %>" class="action-link"
                 onclick="return confirm('Are you sure you want to delete this student (<%= students[i].name %>)?');">
                 Delete
              </a>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

</body>
</html>
